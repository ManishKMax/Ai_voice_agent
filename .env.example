# ─────────────────────────────────────────────────────────────────
#  AI Voice Agent — Environment Variables Template
#  Copy this file to .env and fill in your real values.
#  Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/ai_voice_agent

# ── Authentication ────────────────────────────────────────────────
# Secret used to sign JWT tokens — use a long random string (32+ chars)
JWT_SECRET=your_super_secret_jwt_key_here

# Secret used to sign HTTP sessions
SESSION_SECRET=your_super_secret_session_key_here

# ── Twilio (outbound calling) ─────────────────────────────────────
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# ── Sarvam AI (text-to-speech / speech-to-text) ───────────────────
# Get your API key from https://www.sarvam.ai
SARVAM_API_KEY=your_sarvam_api_key_here

# ── Server ────────────────────────────────────────────────────────
# Port the API server listens on (default: 8080)
PORT=8080

# Node environment: development | production
NODE_ENV=development

# Log level: trace | debug | info | warn | error (default: info)
LOG_LEVEL=info

# Your Replit dev domain (auto-set by Replit, needed for Twilio callbacks)
# Example: your-repl-name.username.repl.co
REPLIT_DEV_DOMAIN=your-repl-name.username.repl.co

# ── AI Agent Defaults ─────────────────────────────────────────────
# These are used as initial defaults and can be overridden via
# the Agent Settings page in the dashboard.

# Agent's name spoken to leads
AGENT_NAME=Alex

# Company name used in the greeting
COMPANY_NAME=Acme Corp

# Product or service being pitched
PRODUCT_NAME=Our Product

# Conversation tone: professional | friendly | casual
AGENT_TONE=friendly

# BCP-47 language code for TTS/STT
AGENT_LANGUAGE=en-IN

# Sarvam TTS voice ID
AGENT_VOICE=meera

# Maximum conversation turns before the agent wraps up
AGENT_MAX_TURNS=6
