modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "GitHub Sync Watcher"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "voice-acceptance-stub"

[[workflows.workflow]]
name = "GitHub Sync Watcher"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/github-sync-watcher.sh"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "voice-acceptance-stub"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/scripts run voice-acceptance-stub"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 23183
externalPort = 3000

[[ports]]
localPort = 25265
externalPort = 3001

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
VITE_CLERK_PUBLISHABLE_KEY = "pk_test_ZGlyZWN0LWVsZi0xMC5jbGVyay5hY2NvdW50cy5kZXYk"

[objectStorage]
defaultBucketID = "replit-objstore-3cb166e9-ee5b-41c0-a57b-3c85d0428e9e"
